#!/bin/bash
Main_version=`uname -r |awk -F'.' '{print $1}'`
Minor_version=`uname -r |awk -F'.' '{print $2}'`
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
cp /tmp/AIC8800/aic.rules /etc/udev/rules.d
udevadm trigger
udevadm control --reload
echo ">>>   udev done"

# --- Force the AIC8800 USB device through its mode-switch cycle ---
# This chip first enumerates as a fake CD-ROM/Mass-Storage device
# (idVendor=a69c, idProduct=5721) and only switches to its real Wi-Fi
# mode (idVendor=2357, idProduct=0147) after being "ejected". The udev
# rule above normally triggers that automatically, but if the device was
# already plugged in before udev/this driver were ready (e.g. right after
# boot), it can be left sitting in the wrong mode. So in addition to the
# udev rule, actively look for the device by either known VID:PID and
# force a USB unbind+rebind (full re-enumeration) to make sure it goes
# through the switch reliably, instead of just hoping the timing lines up.
aic_usb_reset() {
    local found=0
    for devpath in /sys/bus/usb/devices/*; do
        devname="$(basename "$devpath")"
        # only top-level USB devices (e.g. "1-1"), skip interfaces ("1-1:1.0")
        case "$devname" in
            *:*) continue ;;
        esac
        [ -f "$devpath/idVendor" ] || continue
        [ -f "$devpath/idProduct" ] || continue
        vid="$(cat "$devpath/idVendor" 2>/dev/null)"
        pid="$(cat "$devpath/idProduct" 2>/dev/null)"
        case "$vid:$pid" in
            a69c:5721|2357:0147)
                found=1
                echo ">>>   found AIC8800 USB device at ${devname} (${vid}:${pid}), resetting..."
                echo "$devname" > /sys/bus/usb/drivers/usb/unbind 2>/dev/null
                sleep 1
                echo "$devname" > /sys/bus/usb/drivers/usb/bind 2>/dev/null
                sleep 2
                ;;
        esac
    done
    return $((1 - found))
}

if [ -L /dev/aicudisk ]; then
    echo "device exist"
    eject /dev/aicudisk
    sleep 1
fi

aic_usb_reset || echo ">>>   device not exist"
cd /tmp/AIC8800/fw/
rm -rf /lib/firmware/aic8800DC
cp -rf /tmp/AIC8800/fw/aic8800DC /lib/firmware/
echo "cp fw done"

# --- Make sure linux headers for the *currently running* kernel exist ---
# Getting "some" headers package installed is handled by Depends: in
# DEBIAN/control (linux-headers-generic | linux-headers-amd64), so apt
# resolves it BEFORE this postinst runs - that avoids running apt-get from
# inside postinst, which would deadlock against the apt/dpkg lock already
# held by the outer install transaction.
#
# What Depends: can't guarantee is that the installed headers match the
# kernel actually booted right now (e.g. headers were installed for a newer
# kernel than the one currently running, pending a reboot). So we still
# verify that specific match here - if it fails, we stop with a clear,
# actionable message instead of trying to apt-get install anything ourselves.
KERNEL_REL="$(uname -r)"
KERNEL_HEADERS_DIR="/lib/modules/${KERNEL_REL}/build"

if [ -e "$KERNEL_HEADERS_DIR/Makefile" ]; then
    echo ">>>   linux headers already present for kernel ${KERNEL_REL}"
else
    echo ">>>   linux headers for the currently running kernel (${KERNEL_REL})"
    echo ">>>   were not found at ${KERNEL_HEADERS_DIR}."
    echo ">>>   This usually means headers got installed for a different/newer kernel than the one"
    echo ">>>   currently booted. Please install the matching package for your distro, e.g.:"
    echo ">>>     Debian:  sudo apt-get install linux-headers-${KERNEL_REL}  (or linux-headers-amd64)"
    echo ">>>     Ubuntu:  sudo apt-get install linux-headers-${KERNEL_REL}  (or linux-headers-generic)"
    echo ">>>   then reboot if needed, and re-run this install."
    echo ">>>   install Mercury UX3H (AIC8800) Wi-Fi driver failed"
    exit 1
fi

cd /tmp/AIC8800/drivers/aic8800/
make
if [ $? -ne 0 ]; then
    echo ">>>   make failed, install Mercury UX3H (AIC8800) Wi-Fi drvier failed"
    exit 1
fi
make install
if [ $? -ne 0 ]; then
    echo ">>>   make install failed, install Mercury UX3H (AIC8800) Wi-Fi driver failed"
    exit 1
fi
modprobe cfg80211

###   This should be used for virtual machine, not real machine (Also this will be remove in the next update)
#modprobe usbcore
#if ! lsmod | grep -q "^usbcore"; then
#    echo ">>>   usbcore module not available on this kernel."
#    echo ">>>   This usually means no USB controller is exposed to this machine"
#    echo ">>>   (common on VMs without USB passthrough enabled)."
#    echo ">>>   install Mercury UX3H (AIC8800) Wi-Fi driver failed"
#    exit 1
#fi
insmod /tmp/AIC8800/drivers/aic8800/aic_load_fw/aic_load_fw.ko
if [ $? -ne 0 ]; then
    echo ">>>   insmode aic_load_fw failed, install Mercury UX3H (AIC8800) Wi-Fi driver failed"
    exit 1
fi
insmod /tmp/AIC8800/drivers/aic8800/aic8800_fdrv/aic8800_fdrv.ko
if [ $? -ne 0 ]; then
    echo ">>>   insmod aic8800_fdrv failed, install Mercury UX3H (AIC8800) Wi-Fi driver failed"
    exit 1
fi
echo ">>>   insmod done"
cd /tmp/AIC8800/aicrf_test/
make
if [ $? -ne 0 ]; then
    echo ">>>   make failed, install Mercury UX3H (AIC8800) Wi-Fi driver failed"
    exit 1
fi
make install
if [ $? -ne 0 ]; then
    echo ">>>   make install failed, install Mercury UX3H (AIC8800) Wi-Fi driver failed"
    exit 1
fi
echo ""
echo -e "${GREEN}Install Mercury UX3H (AIC8800) Wi-Fi driver successful!!!!!\033[0m"
echo -e "${YELLOW}If you want to remove this driver, the package ID is ${RED}mercury-ux3h-drv${YELLOW}.\033[0m"
exit 0
